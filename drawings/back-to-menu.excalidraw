      "seed": 1175367864,
      "version": 310,
      "versionNonce": 1246382467,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782080893888,
      "link": null,
      "locked": false,
      "text": "Waves of notes come for you to \"play\",\nmeaning that you must press the right\nbutton in the right time that the note\nreaches the square. 2 types of notes:\n\n* Single -> requires just a button press\n* Sequential -> requires press and hold!",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Waves of notes come for you to \"play\",\nmeaning that you must press the right\nbutton in the right time that the note\nreaches the square. 2 types of notes:\n\n* Single -> requires just a button press\n* Sequential -> requires press and hold!",
      "autoResize": true,
      "lineHeight": 1.25
    },
