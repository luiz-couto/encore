    {
      "id": "8o8zCyYqur7vpbAVdsjs7",
      "type": "text",
      "x": 980,
      "y": 440,
      "width": 536.5358276367188,
      "height": 245,
      "angle": 0,
      "strokeColor": "#1e1e1e",
